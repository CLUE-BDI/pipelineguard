{"finding_id": "f_7b000b0ece6b846c61a4e191", "tool": "semgrep", "tool_finding_id": null, "category": "code_issue", "subcategory": null, "severity": "info", "confidence": "medium", "title": "yaml.kubernetes.security.run-as-non-root.run-as-non-root", "description": "When running containers in Kubernetes, it's important to ensure that they  are properly secured to prevent privilege escalation attacks.  One potential vulnerability is when a container is allowed to run  applications as the root user, which could allow an attacker to gain  access to sensitive resources. To mitigate this risk, it's recommended to  add a `securityContext` to the container, with the parameter `runAsNonRoot`  set to `true`. This will ensure that the container runs as a non-root user,  limiting the damage that could be caused by any potential attacks. By  adding a `securityContext` to the container in your Kubernetes pod, you can  help to ensure that your containerized applications are more secure and  less vulnerable to privilege escalation attacks.", "recommendation": null, "rule_id": "yaml.kubernetes.security.run-as-non-root.run-as-non-root", "rule_name": "yaml.kubernetes.security.run-as-non-root.run-as-non-root", "file_path": "/home/demo/de-zoomcamp-project/vulnerable-infra-project/k8s/deployment.yaml", "line_start": 14, "line_end": 14, "code_snippet": "requires login", "resource_type": "source_file", "resource_name": "/home/demo/de-zoomcamp-project/vulnerable-infra-project/k8s/deployment.yaml", "resource_namespace": null, "package_name": null, "installed_version": null, "fixed_version": null, "secret_type": null, "vulnerability_id": null, "repo": "vulnerable-infra-project", "branch": "main", "commit_sha": "local-dev", "pipeline_id": "phase2-local", "scanner_stage": "security_scanners", "timestamp": "2026-03-25T03:47:20+00:00", "status": "open", "environment": "local", "raw_ref": "outputs/vulnerable-infra-project/semgrep.json", "raw_tool": "semgrep", "raw_severity": "INFO", "normalized_ver