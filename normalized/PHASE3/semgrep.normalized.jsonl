{"finding_id": "f_e73a1f9a9340096f1740a344", "tool": "semgrep", "tool_finding_id": null, "category": "code_issue", "subcategory": null, "severity": "medium", "confidence": "medium", "title": "yaml.kubernetes.security.allow-privilege-escalation.allow-privilege-escalation", "description": "In Kubernetes, each pod runs in its own isolated environment with its own set of security policies. However, certain container images may contain `setuid` or `setgid` binaries that could allow an attacker to perform privilege escalation and gain access to sensitive resources. To mitigate this risk, it's recommended to add a `securityContext` to the container in the pod, with the parameter `allowPrivilegeEscalation` set to `false`. This will prevent the container from running any privileged processes and limit the impact of any potential attacks. By adding the `allowPrivilegeEscalation` parameter to your the `securityContext`, you can help to ensure that your containerized applications are more secure and less vulnerable to privilege escalation attacks.", "recommendation": null, "rule_id": "yaml.kubernetes.security.allow-privilege-escalation.allow-privilege-escalation", "rule_name": "yaml.kubernetes.security.allow-privilege-escalation.allow-privilege-escalation", "file_path": "/home/demo/de-zoomcamp-project/vulnerable-infra-project/k8s/deployment.yaml", "line_start": 20, "line_end": 20, "code_snippet": "requires login", "resource_type": "source_file", "resource_name": "/home/demo/de-zoomcamp-project/vulnerable-infra-project/k8s/deployment.yaml", "resource_namespace": null, "package_name": null, "installed_version": null, "fixed_version": null, "secret_type": null, "vulnerability_id": null, "repo": "vulnerable-infra-project", "branch": "main", "commit_sha": "local-dev", "pipeline_id": "phase2-local", "scanner_stage": "security_scanners", "timestamp": "2026-03-25T03:47:20+00:00", "status": "open", "environment": "local", "raw_ref": "outputs/vulnerable-infra-project/semgrep.json", "raw_